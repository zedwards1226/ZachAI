# wpflow configuration — copy to .env and fill in
WPFLOW_SITE_URL=https://example.com
WPFLOW_USERNAME=admin
WPFLOW_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional
# WPFLOW_ALLOW_INSECURE=0
# WPFLOW_TIMEOUT_SECONDS=30
# WPFLOW_LOG_LEVEL=INFO
# WPFLOW_MAX_UPLOAD_MB=25
# WPFLOW_UPLOAD_ROOT=  # comma-separated absolute dirs; defaults to ~/Downloads and ~/Pictures
