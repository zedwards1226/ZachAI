# Copy to .env and fill in. .env is gitignored.

# ─── Paper mode hard stop (one of Zach's 3 hard stops) ───
# OmniAlpha refuses to place orders unless this is exactly "true".
PAPER_MODE=true

# ─── Kalshi credentials (same keys WA uses; share is fine) ───
# Generate at https://kalshi.com/account/settings → API Keys
# Private key path is the file path on this PC, NOT the key itself.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=C:\ZachAI\kalshi\keys\kalshi-private-key.pem

# ─── Anthropic (for any LLM-driven strategy, separate key per bot) ───
# Per CLAUDE.md best practice: one API key per bot for cost segmentation.
ANTHROPIC_API_KEY=

# ─── Telegram (uses existing Jarvis bot via shared trading channel) ───
# OmniAlpha publishes alerts via the same bot WA uses, prefixed [OmniAlpha].
# These are read from the existing trading/.env if not set here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Risk caps (paper-mode defaults; tune as bot proves itself) ───
PER_TRADE_MAX_RISK_USD=20
DAILY_MAX_LOSS_USD=50
WEEKLY_MAX_LOSS_USD=150
MAX_CONCURRENT_POSITIONS=8
