# Copy to omnialpha/.env and fill in. .env is gitignored.

# ─── HARD STOP — one of master CLAUDE.md's 3 hard stops ───
# The bot refuses to place live orders unless this is exactly "true".
# Never flip without Zach's explicit approval.
PAPER_MODE=true

# ─── Starting capital allocated to the longshot-fade strategy ───
# Phase 3 plan: $300 paper. Kelly sizing scales off this.
STARTING_CAPITAL_USD=300

# ─── Kalshi credentials ───
# Paper mode uses only the PUBLIC /markets endpoint (no auth). Keys are
# only needed if you flip to live. Reusing WA's keys is fine.
# KALSHI_API_KEY_ID=
# KALSHI_PRIVATE_KEY_PATH=C:\ZachAI\kalshi\keys\kalshi-private-key.pem

# ─── Telegram alerts (entries, settlements, AM/PM digests) ───
# Reuse the Jarvis bot — alerts prefix [LongshotFade] so they don't mix
# with WA's [WeatherAlpha] feed. Read from trading/.env as fallback.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── Anthropic (reserved for future LLM-driven jobs — unused today) ───
# ANTHROPIC_API_KEY=

# ─── Risk caps (% of LIVE capital with USD floors — defaults in config.py) ───
# Compound up as the bot wins, deleverage automatically on drawdown.
# Uncomment to override config.py defaults.
# PER_TRADE_MAX_RISK_PCT=0.08
# DAILY_MAX_LOSS_PCT=0.16
# WEEKLY_MAX_LOSS_PCT=0.20
# MAX_CONCURRENT_POSITIONS=8
