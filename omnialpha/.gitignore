# Secrets
.env

# Runtime state
state/*.json
state/*.lock
state/*.db
state/*.db-*
*.pid

# Logs
logs/*.log
logs/*.log.*

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
