# Data — historical pulls can be huge, never commit
data/raw/
data/processed/
*.parquet
*.csv

# IDE
.idea/
.vscode/
.DS_Store

# Dashboard build output (regenerated by npm run build)
dashboard/backend/static/
dashboard/frontend/node_modules/
dashboard/frontend/dist/

# Backtest output
backtest/results/
