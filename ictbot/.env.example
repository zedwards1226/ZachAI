# ICTBOT — env template
# Copy to .env and fill in. .env is gitignored.

# ─── Paper-mode hard stop ─────────────────────────────────────────────
# Going live (PAPER_MODE=false) is one of Zach's 3 hard stops.
PAPER_MODE=true

# ─── Observe vs trade ────────────────────────────────────────────────
# Phase 1: SCAN_ONLY=true (detect setups + ping Telegram, do NOT place trades)
# Phase 2: SCAN_ONLY=false (real TV paper trades)
SCAN_ONLY=true

# ─── Symbol ──────────────────────────────────────────────────────────
# Default MES1!. Alternatives: M2K1!, MYM1!, 6E1!
ICT_SYMBOL=MES1!
ICT_TIMEFRAME=5

# ─── CDP (TradingView Desktop, shared with ORB) ──────────────────────
# Updated 2026-05-07: shares ORB's TV Desktop CDP on :9222. ICTBot uses
# its own TV tab pinned to MES1! while ORB keeps a tab on MNQ1!.
CDP_PORT=9222
CDP_HOST=127.0.0.1

# ─── Telegram (NEW bot + channel — do NOT reuse Jarvis bridge) ───────
# Create new bot via @BotFather, get token. Create new private channel, get chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Anthropic (optional — for LLM-driven bias agent in Phase 4) ─────
ANTHROPIC_API_KEY=

# ─── Risk caps ────────────────────────────────────────────────────────
MAX_RISK_PER_TRADE_DOLLARS=150
DAILY_LOSS_LIMIT_DOLLARS=250
WEEKLY_LOSS_LIMIT_DOLLARS=500
MAX_CONSECUTIVE_LOSSES=3
MAX_TRADES_PER_SESSION=3
VIX_HARD_BLOCK=30

# ─── Hours (ET) ──────────────────────────────────────────────────────
NY_AM_START=08:30
NY_AM_END=11:00
NY_PM_START=13:30
NY_PM_END=16:00
HARD_CLOSE=14:55

# ─── Dashboard ────────────────────────────────────────────────────────
DASHBOARD_PORT=3002

# ─── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
