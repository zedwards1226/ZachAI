# Kalshi RSA key auth — get keys at https://demo.kalshi.co (Settings > API Keys)
# 1. Sign up at https://demo.kalshi.co
# 2. Go to Settings > API Keys > Generate Key
# 3. Copy the Key ID (UUID) into KALSHI_API_KEY_ID
# 4. Download the private key .pem file and set KALSHI_PRIVATE_KEY_PATH
KALSHI_API_KEY_ID=your-uuid-key-id-here
KALSHI_PRIVATE_KEY_PATH=C:/ZachAI/kalshi/keys/kalshi_demo_private_key.pem
KALSHI_DEMO=true

# Trading controls
PAPER_MODE=true
STARTING_CAPITAL=1000.00
MAX_BET=100
MAX_DAILY_TRADES=5
MAX_DAILY_LOSS=150
MAX_CAPITAL_AT_RISK=0.40
MAX_CONSECUTIVE_LOSSES=3
MIN_EDGE=0.08
KELLY_FRACTION=0.25

# App
PORT=5000
DATABASE_PATH=C:/ZachAI/kalshi/bots/weatheralpha.db
